{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crane.local/adapter/v0.1/schemas/distro-adapter-binding.schema.json",
  "title": "Distro Adapter Binding v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["distro_id", "binding_id", "version", "resolution_mode", "layers"],
  "properties": {
    "distro_id": {
      "type": "string",
      "minLength": 1
    },
    "binding_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "resolution_mode": {
      "type": "string",
      "enum": ["single", "chain"]
    },
    "layers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["working", "processing", "permanent"],
      "properties": {
        "working": {
          "$ref": "#/$defs/layer_binding"
        },
        "processing": {
          "$ref": "#/$defs/layer_binding"
        },
        "permanent": {
          "$ref": "#/$defs/layer_binding"
        }
      }
    }
  },
  "$defs": {
    "layer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_ids"],
      "properties": {
        "adapter_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(?!cyrune-)(?!forge-)[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      }
    }
  }
}

